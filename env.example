# =============================================================================
# Chat-OS Environment Variables
# Version: 1.0.0 | Status: FROZEN
# Last Updated: 2026-05-19
# =============================================================================
# Copy this file to .env in each app directory and fill in real values.
# NEVER commit .env files to git.
# =============================================================================

# =============================================================================
# SHARED / INFRASTRUCTURE
# =============================================================================

# Redis connection string
# Format: redis://host:port or redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# =============================================================================
# SUPABASE (Managed Service)
# =============================================================================

# Your Supabase project URL (found in Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe for client-side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SERVER ONLY - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret for verifying tokens (found in Supabase Dashboard > Settings > API > JWT Settings)
# This is used by API and Gateway to validate Supabase-issued JWTs
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# API SERVER (apps/api/)
# =============================================================================

# Server port
API_PORT=3001

# PostgreSQL connection (Supabase connection pooling URL recommended)
# Found in Supabase Dashboard > Settings > Database > Connection String
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# Node environment
NODE_ENV=development

# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# =============================================================================
# WEB CLIENT (apps/web/)
# =============================================================================

# Next.js dev port
WEB_PORT=3000

# Public API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Public WebSocket Gateway URL (accessible from browser)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:4000

# Public Supabase URL (for client-side Supabase init)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase Anon Key (for client-side Supabase init)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# GATEWAY (apps/gateway/)
# =============================================================================

# Gateway server port
GATEWAY_PORT=4000

# Redis URL (same as shared)
GATEWAY_REDIS_URL=redis://localhost:6379

# Supabase JWT secret (same as shared, for token validation)
GATEWAY_JWT_SECRET=your-jwt-secret-here

# API server URL (for fallback HTTP calls if needed)
GATEWAY_API_URL=http://localhost:3001/api/v1

# Go environment: development | production
GATEWAY_ENV=development

# Logging level: debug | info | warn | error
GATEWAY_LOG_LEVEL=debug

# =============================================================================
# OPTIONAL / ADVANCED
# =============================================================================

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# Max file upload size in MB
MAX_FILE_SIZE_MB=10

# WebSocket heartbeat interval in seconds
WS_HEARTBEAT_INTERVAL=30

# Presence grace period in seconds (time before marking offline after disconnect)
PRESENCE_GRACE_PERIOD=30

# Message pagination limit default
DEFAULT_PAGE_LIMIT=50

# Max page limit
MAX_PAGE_LIMIT=100
